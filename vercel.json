{
  "functions": {
    "backend/app/main.py": {
      "excludeFiles": "{.next,*.cache,node_modules,public,.git,stale_backup,__pycache__,*.pyc}/**"
    },
    "api/**": {
      "excludeFiles": "{.next,*.cache,node_modules,public,.git,stale_backup,__pycache__,*.pyc}/**"
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}